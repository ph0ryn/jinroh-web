{
  "name": "jinroh-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "db:diff": "supabase db diff --local",
    "db:reset": "supabase db reset --local",
    "dev": "next dev",
    "fix": "oxlint --type-aware --type-check --fix && pnpm run format",
    "format": "pnpm run lint --fix && oxfmt",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "git config core.hooksPath .githooks",
    "lint": "eslint && oxlint --type-aware --type-check",
    "lint:db": "supabase db lint --local",
    "precommit": "pnpm run fix && eslint",
    "start": "next start",
    "test": "pnpm run test:unit",
    "test:all": "pnpm run test:unit && pnpm run db:reset && pnpm run test:db && E2E_SKIP_DB_RESET=1 pnpm run test:e2e",
    "test:db": "supabase test db",
    "test:e2e": "playwright test",
    "test:e2e:all": "pnpm run test:e2e",
    "test:e2e:roles": "playwright test --grep @roles",
    "test:e2e:security": "playwright test --grep @security",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@gsap/react": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "gsap": "catalog:",
    "next": "catalog:",
    "qrcode.react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "sort-package-json": "catalog:",
    "supabase": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.1.1"
}
